{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://w.behold.so; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: data:; connect-src 'self' https://*.behold.so; frame-ancestors 'none'; base-uri 'self'; form-action 'none'" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/servicios",
      "destination": "/sesiones",
      "permanent": true
    },
    {
      "source": "/servicios/",
      "destination": "/sesiones",
      "permanent": true
    },
    {
      "source": "/circulos-de-hombres-valencia",
      "destination": "/circulos-hombres",
      "permanent": true
    },
    {
      "source": "/circulos-de-hombres-valencia/",
      "destination": "/circulos-hombres",
      "permanent": true
    },
    {
      "source": "/breathwork-valencia",
      "destination": "/breathwork",
      "permanent": true
    },
    {
      "source": "/breathwork-valencia/",
      "destination": "/breathwork",
      "permanent": true
    },
    {
      "source": "/activacion-energetica",
      "destination": "/sesiones",
      "permanent": true
    },
    {
      "source": "/activacion-energetica/",
      "destination": "/sesiones",
      "permanent": true
    },
    {
      "source": "/circulos-hombres-valencia",
      "destination": "/circulos-hombres",
      "permanent": true
    },
    {
      "source": "/circulos-hombres-valencia/",
      "destination": "/circulos-hombres",
      "permanent": true
    },
    {
      "source": "/bano-sonido-valencia",
      "destination": "/bano-sonido",
      "permanent": true
    },
    {
      "source": "/bano-sonido-valencia/",
      "destination": "/bano-sonido",
      "permanent": true
    },
    {
      "source": "/agenda/eternity-junio",
      "destination": "/agenda",
      "permanent": true
    }
  ]
}
